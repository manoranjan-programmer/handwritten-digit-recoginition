# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
dist/
.vite/
*.local

# ── Python / Backend ─────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Model cache (downloaded at runtime, not committed) ────────────────────────
model_cache/
*.keras
*.h5

# ── Environment files (contain secrets) ──────────────────────────────────────
.env
.env.local
.env.production
.env.staging
# Keep .env.example committed — it documents required variables

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────────────────────
# Don't ignore Dockerfile itself — it's intentionally committed

# ── Test artefacts ────────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml
